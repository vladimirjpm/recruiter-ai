# ConnectionStrings__Postgres takes precedence over appsettings.json
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=recruiter_ai;Username=recruiter;Password=recruiter

# OpenAI API key — required for Stage 4 (evaluation) and Stage 6 (CV generator)
OpenAI__ApiKey=
OpenAI__Model=gpt-4o-mini
OpenAI__EmbeddingModel=text-embedding-3-small
