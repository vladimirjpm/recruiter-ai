# Used by docker-compose.yml — injected into the container as Llm__ApiKey
# (Docker Compose reads this file automatically if it lives next to docker-compose.yml)
LLM_API_KEY=

# ── Direct API env vars (for dotnet run without Docker) ───────────────────────
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=recruiter_ai;Username=recruiter;Password=recruiter

# OpenAI — section name is "Llm" (not "OpenAI") — double-underscore = colon separator
Llm__ApiKey=
Llm__Model=gpt-4o-mini
Llm__EmbeddingModel=text-embedding-3-small

# CORS — add Vercel URL when deploying
# Cors__AllowedOrigins__0=https://your-app.vercel.app
