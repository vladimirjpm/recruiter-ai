# Base URL of the .NET API (no trailing slash).
# In development, leave unset — Vite proxies /api to http://localhost:5150.
# In production (Vercel), set to the Railway API URL.
# VITE_API_URL=https://your-app.railway.app

# Feature flags (baked in at build time via Vite).
# Synthetic CV Generator — dev/QA tooling, not part of the recruiter workflow.
# Set to "true" in .env.development; leave unset or set to "false" in production.
# VITE_ENABLE_SYNTHETIC_GENERATOR=true
